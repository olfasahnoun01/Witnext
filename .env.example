# Copy to .env.local and fill with your Supabase project (Dashboard → Settings → API).
# Never commit .env.local or put the service_role key in Vite env (browser-exposed).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key

# Server-side scripts only (migrate:storage-prefix, import:fiches:apply). NOT exposed to Vite.
# Supabase Dashboard → Settings → API → service_role secret
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# hCaptcha site key (public). Used on login and marketing lead forms.
# VITE_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key

# Optional marketing demo video (YouTube, Vimeo, or local path e.g. /videos/witnext-demo.mp4)
# VITE_MARKETING_VIDEO_URL=https://www.youtube.com/watch?v=YOUR_VIDEO_ID

# Supabase Edge Function secret (Dashboard → Edge Functions → Secrets, or `supabase secrets set`):
# HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key

# Build target: web (Vercel/browser) or electron (Windows installer). Set by npm scripts.
# VITE_APP_TARGET=web
